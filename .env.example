# Copy this file to .env and fill in real values. Never commit .env.

# Secret token required to read submissions via GET /api/submissions
# and /api/submissions.csv. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# Comma-separated list of origins allowed to POST to the API.
# Add your local dev server and, once deployed, your GitHub Pages URL.
ALLOWED_ORIGINS=https://autopermit.github.io,http://localhost:8000,http://127.0.0.1:8000

# Optional: override where the SQLite file is written.
# DATABASE_PATH=/absolute/path/to/submissions.db
